# =============================================================================
# Production RAG Application — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- LiteLLM (optional overrides) ---
LITELLM_MODEL=gpt-4o
LITELLM_EMBEDDING_MODEL=text-embedding-3-large

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_documents

# --- Elasticsearch (BM25) ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=rag_bm25

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5432/ragdb

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600

# --- MinIO / S3 ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rag-documents
S3_REGION=us-east-1

# --- Langfuse (tracing) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=rag-backend

# --- Reranker ---
RERANKER_MODEL=BAAI/bge-reranker-large
RERANKER_DEVICE=cpu          # cpu | cuda | mps

# --- Retrieval ---
BM25_TOP_K=20
VECTOR_TOP_K=20
RERANK_TOP_K=5
RRF_K=60                     # RRF constant

# --- Generation ---
MAX_CONTEXT_CHUNKS=5
MAX_RETRIES_CITATION=2       # Max LLM retries on hallucinated citations

# --- Evaluation thresholds (CI gate) ---
EVAL_FAITHFULNESS_THRESHOLD=0.85
EVAL_RELEVANCE_THRESHOLD=0.80

# --- App ---
APP_ENV=development          # development | production
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
